# Copy this file to .env and fill in real values before running tests.
# playwright.config.cjs and tests read these via process.env (loaded with dotenv).

# ── Backend API ──────────────────────────────────────────────
API_BASE_URL=http://localhost:3000

# ── Frontend apps (for UI E2E specs) ─────────────────────────
WEB_BASE_URL=http://localhost:5173
ADMIN_BASE_URL=http://localhost:5174
MOBILE_BASE_URL=http://localhost:5175

# ── Seed accounts (used by fixtures/auth.cjs to obtain JWTs) ─
ADMIN_EMAIL=admin@eshop.com
ADMIN_PASSWORD=Admin123!

USER_EMAIL=test@eshop.com
USER_PASSWORD=Test1234!

# ── Login endpoint (adjust if different) ─────────────────────
LOGIN_PATH=/api/login

# ── Misc ──────────────────────────────────────────────────────
# Set to "true" to run UI specs (frontend) in addition to API specs
RUN_UI_SPECS=false
